# Local data and derived results. Keep only lightweight documentation files.
data/*
!data/README.md
results/*
!results/.gitkeep
logs/*
!logs/.gitkeep

# Large tabular/model artifacts
*.fst
*.rds
*.Rds
*.csv.gz
*.tsv.gz

# renv local library/cache; commit renv.lock and renv/activate.R if generated.
renv/library/
renv/staging/
renv/python/
renv/sandbox/

